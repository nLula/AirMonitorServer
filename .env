# ── AirMonitor server configuration ─────────────────────────────
# Same key as API_KEY in AirMonitorSensor include/config.h
SENSOR_API_KEY=7VF6dJxpILYtMpGhiJhkMVS50SWuVczZtBX0MgqAWv3zJgiC96JCDorR21Jrcypx

# How often the collector polls all sensors (standard crontab syntax)
CRON_SCHEDULE=*/5 * * * *

# Per-request timeout when contacting a sensor (seconds)
POLL_TIMEOUT_S=5

# How many days of check records to keep in history.json
HISTORY_RETENTION_DAYS=30

# Full network rescan at least this often (minutes) - how quickly a
# brand-new sensor is picked up without restarting the collector
DISCOVERY_RESCAN_MIN=60

# Port on THIS machine where the frontend is reachable:
# http://<this-pc-ip>:8080
FRONTEND_PORT=8080

TZ=Europe/Tallinn
